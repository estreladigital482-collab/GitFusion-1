PORT=3737
WORKSPACE_DIR=./workspaces
DATA_DIR=./data
GITHUB_TOKEN=

# IA do GitFusion
# auto: tenta IA local, depois online, depois fallback offline
# offline: não usa rede externa
# ollama: força Ollama local
# openai-compatible: usa endpoint compatível com OpenAI/Kimi/OpenRouter/LM Studio
GITFUSION_AI_PROVIDER=auto
GITFUSION_AI_LOCAL_URL=http://127.0.0.1:11434
GITFUSION_AI_LOCAL_MODEL=qwen2.5-coder:7b
GITFUSION_AI_BASE_URL=
GITFUSION_AI_MODEL=
GITFUSION_AI_TOKEN=
GITFUSION_ENABLE_TERMINAL=false

# GitHub publish
GITHUB_TOKEN=
GITHUB_DEFAULT_PRIVATE=true
GITHUB_DEFAULT_BRANCH=main
